---
import ServicePage from "../layouts/ServicePage.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "graphics");
const content = entry!.data;

import hero    from "../assets/heros/web-graphic-design.webp";
import feature1 from "../assets/features/design/made-simple.jpg";
import feature2 from "../assets/features/design/consistent-look.jpg";
import icon    from "../assets/icons/graphics.png";

const imageMap = { hero, feature1, feature2, icon };
---

<ServicePage content={content} imageMap={imageMap} />