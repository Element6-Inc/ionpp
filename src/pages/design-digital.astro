---
import ServicePage from "../layouts/ServicePage.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "graphics");
const content = entry!.data;

import hero    from "../assets/heros/web-graphic-design.webp";
import feature1 from "../assets/features/design/smart-design.webp";
import feature2 from "../assets/features/design/designed-here.webp";
import feature3 from "../assets/features/design/design-support.webp";
import icon     from "../assets/icons/animated/design.gif";

const imageMap = { hero, feature1, feature2, feature3, icon };
---

<ServicePage content={content} imageMap={imageMap} />