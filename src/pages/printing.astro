---
import ServicePage from "../layouts/ServicePage.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "printing");
const content = entry!.data;

import hero     from "../assets/heros/printing-main.webp";
import feature1 from "../assets/features/printing/professional-printing.webp";
import feature2 from "../assets/features/printing/local-printing.webp";
import icon     from "../assets/icons/printing.png";

const imageMap = { hero, feature1, feature2, icon };
---

<ServicePage content={content} imageMap={imageMap} />