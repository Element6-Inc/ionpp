---
import InnerServicePage from "../../layouts/InnerServicePage.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "signs/lawn-event-signs");
const content = entry!.data;

import hero          from "../../assets/heros/signs/outdoor.webp";
import feature1      from "../../assets/features/signs/wind-flag.webp";
import animatedIcon  from "../../assets/icons/animated/lawn.gif";
---

<InnerServicePage content={content} imageMap={{ hero, feature1 }} animatedIcon={animatedIcon} />
