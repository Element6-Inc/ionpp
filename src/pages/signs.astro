---
import ServicePage from "../layouts/ServicePage.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "signs");
const content = entry!.data;

import hero     from "../assets/heros/signs-hero.webp";
import feature1 from "../assets/features/signs/wind-flag.webp";
import feature2 from "../assets/features/signs/the-elements.webp";
import icon     from "../assets/icons/sign.png";

const imageMap = { hero, feature1, feature2, icon };
---

<ServicePage content={content} imageMap={imageMap} />