---
import InnerServicePage from "../../layouts/InnerServicePage.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "promo/drinkware");
const content = entry!.data;

import hero          from "../../assets/heros/promo/drinks.webp";
import icon          from "../../assets/icons/promo.png";
import feature1      from "../../assets/features/promo/drinkware-1.webp";
import feature2     from "../../assets/features/promo/drinkware-2.webp";
import animatedIcon  from "../../assets/icons/animated/water.gif";
---

<InnerServicePage content={content} imageMap={{ hero, icon, feature1, feature2 }} animatedIcon={animatedIcon} />
