---
import Layout from "../layouts/Layout.astro";
import SmallHero from "../components/hero/HeroSmall.astro";
import CentreText from "../components/content/CentreText.astro";
import Feature from "../components/content/Feature.astro";
import ChecklistGrid from "../components/content/Checklistgrid.astro";
import AccordionSection from "../components/accordions/AccordionSection.astro";
import CTA from "../components/content/CTA.astro";
import ServiceAreaModal from "../components/interactive/ServiceAreaModal.astro";

import { getEntry } from "astro:content";
const entry = await getEntry("pages", "real-estate-signs");
const content = entry!.data;

import hero from "../assets/heros/realtors.webp";
import feature1 from "../assets/features/realtors/experience.webp";
import feature2 from "../assets/features/realtors/realtor-instal.webp";
import feature3 from "../assets/features/realtors/realtor-printing.webp";
import feature4 from "../assets/features/realtors/realtor-promo.webp";
import icon from "../assets/icons/animated/for-sale.gif";

const imageMap = { hero, feature1, feature2, feature3, feature4, icon };
const features = content.features ?? [];
const accordions = content.accordions ?? [];
const mapToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;
const installMap = content.installMap;
---

<Layout title={content.site.title} description={content.site.description}>
  <!-- HERO -->
  <SmallHero
    title={content.hero.title}
    imageSrc={imageMap.hero}
    imageAlt={content.hero.imageAlt}
    bgColor={content.hero.bgColor}
  />

  <!-- CENTRE TEXT -->
  {
    content.centreText && (
      <section class="sm:pt-12 relative bg-slate-50">
        <CentreText
          title={content.centreText.title}
          description={content.centreText.description}
          imageSrc={
            imageMap[
              (content.centreText.icon ?? "icon") as keyof typeof imageMap
            ].src
          }
          imageAlt="ION Group Logo"
        />
      </section>
    )
  }

  <!-- CHECKLIST -->
  {
    content.services && (
      <section class="bg-slate-50">
        <div class="pt-6">
          <ChecklistGrid items={content.services.checklist} />
        </div>
      </section>
    )
  }

  <!-- FEATURES -->
  <section class="pt-6 sm:pb-20 sm:pt-32 sm:-mt-24 bg-white">
    {
      features.map((feature: any) => (
        <div id={feature.id}>
          <Feature
            title={feature.title}
            description={feature.description}
            imageSrc={
              imageMap[(feature.image ?? "hero") as keyof typeof imageMap]
            }
            imageAlt={feature.imageAlt}
            imagePosition={feature.imagePosition}
            buttonLink={feature.buttonLink}
            buttonText={feature.buttonText}
            buttonTarget={feature.buttonTarget}
          />
        </div>
      ))
    }
  </section>

  <!-- SERVICE AREA MODAL -->
  {
    mapToken && installMap && (
      <ServiceAreaModal token={mapToken} installMap={installMap} />
    )
  }

  <!-- ACCORDION -->
  <AccordionSection
    items={accordions}
    heading={content.accordionHeading}
    loadMoreAt={5}
  />

  <!-- CTA -->
  {
    content.cta && (
      <CTA
        heading={content.cta.heading}
        button={content.cta.button}
        link={content.cta.link}
      />
    )
  }
</Layout>
