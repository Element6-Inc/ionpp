---
import InnerServicePage from "../../layouts/InnerServicePage.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "printing/business-cards");
const content = entry!.data;

import hero          from "../../assets/heros/printing/business-cards.webp";
import icon          from "../../assets/icons/printing/books.png";
import feature1      from "../../assets/features/printing/business-cards-1.webp";
import feature2      from "../../assets/features/printing/business-cards-2.webp";
import animatedIcon  from "../../assets/icons/animated/namecard.gif";
---

<InnerServicePage content={content} imageMap={{ hero, icon, feature1, feature2 }} animatedIcon={animatedIcon} />
