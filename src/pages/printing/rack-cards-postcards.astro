---
import InnerServicePage from "../../layouts/InnerServicePage.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "printing/rack-cards-postcards");
const content = entry!.data;

import hero          from "../../assets/heros/printing/rackcards.webp";
import icon          from "../../assets/icons/printing/rackcard.png";
import feature1      from "../../assets/features/printing/intro-image.webp";
import animatedIcon  from "../../assets/icons/animated/postcard.gif";
---

<InnerServicePage content={content} imageMap={{ hero, icon, feature1 }} animatedIcon={animatedIcon} />
