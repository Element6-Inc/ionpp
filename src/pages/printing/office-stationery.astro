---
import InnerServicePage from "../../layouts/InnerServicePage.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "printing/office-stationery");
const content = entry!.data;

import hero          from "../../assets/heros/printing/office.webp";
import icon          from "../../assets/icons/printing/books.png";
import feature1      from "../../assets/features/printing/business-cards-1.webp";
import animatedIcon  from "../../assets/icons/animated/notebook.gif";
---

<InnerServicePage content={content} imageMap={{ hero, icon, feature1 }} animatedIcon={animatedIcon} />
