---
import ServicePage from "../layouts/ServicePage.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "promo");
const content = entry!.data;

import hero     from "../assets/heros/promotional.webp";
import feature1 from "../assets/features/promo/promo-products.webp";
import feature2 from "../assets/features/promo/showroom.webp";
import icon     from "../assets/icons/promo.png";

const imageMap = { hero, feature1, feature2, icon };
---

<ServicePage content={content} imageMap={imageMap} />