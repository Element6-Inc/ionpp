---
import Layout from "../layouts/Layout.astro";
import SmallHero from "../components/hero/HeroSmall.astro";
import CentreText from "../components/content/CentreText.astro";
import CTA from "../components/content/CTA.astro";
import { Image } from "astro:assets";
import { ctas, randomCtaPool, randomPrintCtaPool, randomPromoCtaPool, randomSignsCtaPool } from "../data/ctas";

interface Props {
  content: any;
  imageMap: Record<string, ImageMetadata>;
  animatedIcon?: ImageMetadata;
}

const { content, imageMap, animatedIcon } = Astro.props;

const features = content.features ?? [];

// Feature carousel — supports 1–4 images.
// Accepts featureImages (array) or falls back to the legacy featureImage (single).
const rawFeatureImages: { image: string; imageAlt: string }[] =
  Array.isArray(content.featureImages)
    ? content.featureImages.slice(0, 4)
    : content.featureImage
      ? [content.featureImage]
      : [];

// Keep only entries whose image key is present in imageMap.
const featureImages = rawFeatureImages.filter((f) => imageMap[f.image]);
const showDots = featureImages.length > 1;

// CTA — resolved from key, random pool, or inline definition
const isRandom       = content.ctaKey === "random";
const isRandomPrint  = content.ctaKey === "random-print";
const isRandomPromo  = content.ctaKey === "random-promo";
const isRandomSigns  = content.ctaKey === "random-signs";
const activePool     = isRandomPrint ? randomPrintCtaPool
                     : isRandomPromo ? randomPromoCtaPool
                     : isRandomSigns ? randomSignsCtaPool
                     : randomCtaPool;
const cta = (isRandom || isRandomPrint || isRandomPromo || isRandomSigns)
  ? activePool[0]                           // fallback for no-JS / build output
  : content.ctaKey
    ? ctas[content.ctaKey]
    : content.cta;
---

<Layout title={content.site.title} description={content.site.description} noindex={true}>

  <!-- HERO -->
  <SmallHero
    title={content.hero.title}
    imageSrc={imageMap[content.hero.image]}
    imageAlt={content.hero.imageAlt}
    bgColor={content.hero.bgColor}
  />

  <!-- CENTRE TEXT -->
  <section class="sm:pt-12 relative bg-slate-50">
    {content.centreText && (
      <CentreText
        title={content.centreText.title}
        description={content.centreText.description}
        imageSrc={animatedIcon?.src}
        imageClass="h-24 w-auto"
      />
    )}
  </section>

  <!-- FEATURE IMAGE / CAROUSEL — replaces tab nav, same overlap position -->
  {featureImages.length === 1 && (
    <section class="inner-svc-img">
      <div class="inner-svc-img__wrap">
        <Image
          src={imageMap[featureImages[0].image]}
          alt={featureImages[0].imageAlt}
          width={1400}
          height={600}
          quality={90}
          sizes="(max-width: 768px) 100vw, 896px"
          class="inner-svc-img__img"
          loading="eager"
          decoding="async"
        />
      </div>
    </section>
  )}

  {featureImages.length > 1 && (
    <section class="inner-svc-img">
      <div class="inner-svc-carousel__wrap">
        <!-- Slide track -->
        <div class="inner-svc-carousel__track" aria-live="polite" aria-atomic="true">
          {featureImages.map((f, i) => (
            <div
              class={`inner-svc-carousel__slide${i === 0 ? " active" : ""}`}
              data-index={i}
              aria-hidden={i !== 0}
            >
              <Image
                src={imageMap[f.image]}
                alt={f.imageAlt}
                width={1400}
                height={600}
                quality={90}
                sizes="(max-width: 768px) 100vw, 896px"
                loading={i === 0 ? "eager" : "lazy"}
                decoding="async"
              />
            </div>
          ))}
        </div>

        <!-- Overlay dots -->
        {showDots && (
          <nav class="inner-svc-carousel__dots" aria-label="Feature image navigation">
            {featureImages.map((f, i) => (
              <button
                class={`inner-svc-carousel__dot${i === 0 ? " active" : ""}`}
                data-index={i}
                aria-label={`Show image ${i + 1}`}
                aria-current={i === 0}
              />
            ))}
          </nav>
        )}
      </div>
    </section>
  )}

  <!-- BLOG ARTICLE — all features flow as one continuous piece -->
  <section class="inner-svc-content">
    <article class="panel-blog">
      <div class="panel-blog__inner">

        {features.map((feature: any, i: number) => (
          <section
            id={feature.id}
            class={`panel-blog__section${i > 0 ? " panel-blog__section--divided" : ""}`}
            data-blog-section={feature.id}
          >
            <h3 class="panel-blog__section-title max-w-2xl text-balance">{feature.title}</h3>
            <div class="panel-blog__body" set:html={feature.description} />

            {feature.buttonLink && feature.buttonText && (
              <div class="mt-8">
                <a
                  href={feature.buttonLink}
                  target={feature.buttonTarget || "_self"}
                  rel={feature.buttonTarget === "_blank" ? "noopener noreferrer" : undefined}
                  class="btn btn-secondary"
                >
                  {feature.buttonText}
                </a>
              </div>
            )}
          </section>
        ))}

      </div>
    </article>
  </section>

  <!-- CTA -->
  {cta && (
    <div id="cta-wrapper">
      <CTA
        heading={cta.heading}
        button={cta.button}
        link={cta.link}
      />
    </div>
  )}

  {(isRandom || isRandomPrint || isRandomPromo || isRandomSigns) && (
    <script is:inline set:html={`
      (function () {
        function randomizeCta() {
          var pool = ${JSON.stringify(activePool)};
          var currentPath = window.location.pathname.replace(/\\/$/, "");
          var filtered = pool.filter(function(item) { return item && item.link.replace(/\\/$/, "") !== currentPath; });
          var available = filtered.length ? filtered : pool.filter(Boolean);
          var pick = available[Math.floor(Math.random() * available.length)];
          if (!pick) return;
          var heading = document.querySelector("#cta-wrapper .cta-heading");
          var btn = document.querySelector("#cta-wrapper .btn-cta-white");
          if (heading) heading.textContent = pick.heading;
          if (btn) { btn.textContent = pick.button; btn.setAttribute("href", pick.link); }
        }
        document.addEventListener("astro:page-load", randomizeCta);
      })();
    `} />
  )}

</Layout>
