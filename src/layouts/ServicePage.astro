---
/* =======================================================
 * ServicePage.astro
 * Shared layout for all service pages (printing, signs,
 * promo, design). Each page passes its content + imageMap.
 * ======================================================= */

/* =======================================================
 * COMPONENT IMPORTS
 * ======================================================= */
import Layout from "../layouts/Layout.astro";
import SmallHero from "../components/hero/HeroSmall.astro";
import { getImage } from "astro:assets";
import CentreText from "../components/content/CentreText.astro";
import Feature from "../components/content/Feature.astro";
import ChecklistGrid from "../components/content/Checklistgrid.astro";
import AccordionSection from "../components/accordions/AccordionSection.astro";
import CTA from "../components/content/CTA.astro";

/* =======================================================
 * PROPS
 * ======================================================= */
interface Props {
  content: any;
  imageMap: Record<string, ImageMetadata>;
  checklistBg?: string; // optional override, defaults to "bg-slate-50"
}

const { content, imageMap, checklistBg = "bg-slate-50" } = Astro.props;

const features = content.features ?? [];
const accordions = content.accordions ?? [];

const preloadedHero = await getImage({ src: imageMap[content.hero.image], width: 1400, height: 900, format: "webp" });
---

<Layout title={content.site.title} description={content.site.description} preloadImageSrc={preloadedHero.src}>
  <!-- HERO SECTION -->
  <SmallHero
    title={content.hero.title}
    imageSrc={imageMap[content.hero.image]}
    imageAlt={content.hero.imageAlt}
    bgColor={content.hero.bgColor}
  />

  <!-- CENTRE TEXT SECTION -->
  <section class={`sm:pt-12 relative ${checklistBg}`}>
    <CentreText
      title={content.centreText.title}
      description={content.centreText.description}
      imageSrc={imageMap[content.centreText.icon].src}
      imageAlt="ION Group Logo"
    />
  </section>

  <!-- CHECKLIST SECTION -->
  <section class={checklistBg}>
    <div class="pt-6">
      <ChecklistGrid items={content.services.checklist} />
    </div>
  </section>

  <!-- FEATURE SECTIONS -->
  <section class="pt-6 sm:pb-20 sm:pt-32 sm:-mt-24 bg-white">
    {
      features.map((feature: any) => (
        <div id={feature.id}>
          <Feature
            title={feature.title}
            description={feature.description}
            imageSrc={imageMap[feature.image]}
            imageAlt={feature.imageAlt}
            imagePosition={feature.imagePosition}
            buttonLink={feature.buttonLink}
            buttonText={feature.buttonText}
            buttonTarget={feature.buttonTarget}
          />
        </div>
      ))
    }
  </section>

  <!-- ACCORDION SECTION (optional — only renders if content.accordions exists) -->
  <AccordionSection items={accordions} heading={content.accordionHeading} />

  <!-- CTA SECTION -->
  <CTA
    heading={content.cta.heading}
    button={content.cta.button}
    link={content.cta.link}
  />
</Layout>
