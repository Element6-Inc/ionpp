---
interface Props {
  token: string;
}
const { token } = Astro.props;
---

<!-- Mapbox CSS -->
<link href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css" rel="stylesheet" />
<link href="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-geocoder/v5.0.1/mapbox-gl-geocoder.css" rel="stylesheet" />

<!-- Pass token via data attribute to avoid define:vars issues with ClientRouter -->
<div id="sam-wrapper" data-token={token} class="w-full rounded-2xl overflow-hidden shadow-md border border-gray-200 bg-white">

  <!-- Header -->
  <div class="p-6 border-b border-gray-100">
    <h3 class="text-lg font-semibold text-gray-900 mb-1">Check your install area</h3>
    <p class="text-sm text-gray-500 mb-4">Enter your address to see if an install surcharge applies to your location.</p>
    <div id="sam-geocoder"></div>
  </div>

  <!-- Map -->
  <div id="sam-map" style="height: 380px;"></div>

  <!-- Result -->
  <div id="sam-result" class="hidden p-6 border-t border-gray-100"></div>

</div>

<style is:global>
  #sam-geocoder .mapboxgl-ctrl-geocoder {
    width: 100%;
    max-width: 100%;
    box-shadow: none;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    font-family: inherit;
  }
  #sam-geocoder .mapboxgl-ctrl-geocoder--input {
    padding: 0.625rem 2.5rem;
    font-size: 0.875rem;
    color: #111827;
  }
  #sam-geocoder .mapboxgl-ctrl-geocoder--input:focus {
    outline: 2px solid #DA2C43;
    outline-offset: -2px;
  }
  .mapboxgl-ctrl-attrib,
  .mapboxgl-ctrl-logo {
    display: none !important;
  }
</style>

<script>
  const BARRIE_POLYGON = {
    type: 'Feature',
    geometry: {
      type: 'Polygon',
      coordinates: [[
        [-79.756, 44.370],
        [-79.756, 44.408],
        [-79.730, 44.428],
        [-79.700, 44.435],
        [-79.670, 44.428],
        [-79.640, 44.410],
        [-79.622, 44.390],
        [-79.625, 44.365],
        [-79.645, 44.345],
        [-79.675, 44.336],
        [-79.710, 44.338],
        [-79.740, 44.350],
        [-79.756, 44.370],
      ]]
    }
  };

  function loadScript(src: string): Promise<void> {
    return new Promise((resolve, reject) => {
      if (document.querySelector(`script[src="${src}"]`)) { resolve(); return; }
      const s = document.createElement('script');
      s.src = src;
      s.onload = () => resolve();
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  function isInBarrie(feature: any): boolean {
    if (!feature) return false;
    if (feature.context) {
      const place = feature.context.find((c: any) => c.id?.startsWith('place.'));
      if (place?.text === 'Barrie') return true;
    }
    if (feature.place_type?.includes('place') && feature.text === 'Barrie') return true;
    return false;
  }

  function showResult(inBarrie: boolean, placeName: string) {
    const el = document.getElementById('sam-result');
    if (!el) return;
    if (inBarrie) {
      el.innerHTML = `
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900">Within Barrie</p>
            <p class="text-sm text-gray-400 mt-0.5">${placeName}</p>
            <p class="text-sm text-green-700 font-medium mt-2">Standard installation rate — no surcharge.</p>
          </div>
        </div>`;
    } else {
      el.innerHTML = `
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-4 h-4" style="color:#DA2C43" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900">Outside Barrie</p>
            <p class="text-sm text-gray-400 mt-0.5">${placeName}</p>
            <p class="text-sm font-medium mt-2" style="color:#DA2C43;">+$20 install surcharge applies to this location.</p>
            <p class="text-xs text-gray-400 mt-1">Contact us to confirm pricing for your order.</p>
          </div>
        </div>`;
    }
    el.classList.remove('hidden');
  }

  async function initMap() {
    // Only run on pages that have the map container
    const wrapper = document.getElementById('sam-wrapper');
    if (!wrapper) return;

    const token = wrapper.dataset.token;
    if (!token) return;

    // Load scripts once — subsequent calls resolve immediately if already loaded
    await loadScript('https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js');
    await loadScript('https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-geocoder/v5.0.1/mapbox-gl-geocoder.min.js');

    const mapboxgl = (window as any).mapboxgl;
    const MapboxGeocoder = (window as any).MapboxGeocoder;

    mapboxgl.accessToken = token;

    // Clear geocoder container before re-mounting (ClientRouter re-runs this)
    const geocoderEl = document.getElementById('sam-geocoder');
    if (geocoderEl) geocoderEl.innerHTML = '';

    const map = new mapboxgl.Map({
      container: 'sam-map',
      style: 'mapbox://styles/mapbox/light-v11',
      center: [-79.6903, 44.3894],
      zoom: 10,
    });

    map.on('load', () => {
      map.addSource('barrie', { type: 'geojson', data: BARRIE_POLYGON });
      map.addLayer({
        id: 'barrie-fill',
        type: 'fill',
        source: 'barrie',
        paint: { 'fill-color': '#DA2C43', 'fill-opacity': 0.08 },
      });
      map.addLayer({
        id: 'barrie-outline',
        type: 'line',
        source: 'barrie',
        paint: { 'line-color': '#DA2C43', 'line-width': 2, 'line-opacity': 0.5 },
      });
    });

    const geocoder = new MapboxGeocoder({
      accessToken: token,
      mapboxgl,
      placeholder: 'Enter your address or city...',
      countries: 'ca',
      proximity: { longitude: -79.6903, latitude: 44.3894 },
      marker: { color: '#DA2C43' },
    });

    geocoderEl?.appendChild(geocoder.onAdd(map));

    geocoder.on('result', (e: any) => {
      showResult(isInBarrie(e.result), e.result.place_name);
    });

    geocoder.on('clear', () => {
      document.getElementById('sam-result')?.classList.add('hidden');
    });
  }

  // Run on first load and every ClientRouter page transition
  document.addEventListener('astro:page-load', initMap);
</script>
