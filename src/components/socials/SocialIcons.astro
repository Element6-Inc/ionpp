---
import socialData from "../../data/social.json";

// Social icon SVG generation with slate-500 and sky-500 hover colors
const getSocialIcon = (platform: string) => {
  const iconMap = {
    facebook: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="social-icon-svg">
      <circle cx="12" cy="12" r="11" class="icon-circle" />
      <path class="icon-path" d="M10.2,19v-7h-1.4v-2.4h1.4v-1.5c0-2,0.8-3.1,3.1-3.1h1.9v2.4h-1.2c-0.9,0-1,0.3-1,1v1.2h2.2l-0.3,2.4h-1.9v7h-2.8z" />
    </svg>`,
    instagram: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="social-icon-svg">
      <circle cx="12" cy="12" r="11" class="icon-circle" />
      <path class="icon-path" d="M12,7.2c1.6,0,1.8,0,2.4,0c0.6,0,0.9,0.1,1.1,0.2c0.3,0.1,0.5,0.2,0.7,0.4c0.2,0.2,0.3,0.4,0.4,0.7c0.1,0.2,0.2,0.5,0.2,1.1 c0,0.6,0,0.8,0,2.4s0,1.8,0,2.4c0,0.6-0.1,0.9-0.2,1.1c-0.1,0.3-0.2,0.5-0.4,0.7c-0.2,0.2-0.4,0.3-0.7,0.4c-0.2,0.1-0.5,0.2-1.1,0.2 c-0.6,0-0.8,0-2.4,0s-1.8,0-2.4,0c-0.6,0-0.9-0.1-1.1-0.2c-0.3-0.1-0.5-0.2-0.7-0.4c-0.2-0.2-0.3-0.4-0.4-0.7c-0.1-0.2-0.2-0.5-0.2-1.1 c0-0.6,0-0.8,0-2.4s0-1.8,0-2.4c0-0.6,0.1-0.9,0.2-1.1c0.1-0.3,0.2-0.5,0.4-0.7c0.2-0.2,0.4-0.3,0.7-0.4c0.2-0.1,0.5-0.2,1.1-0.2 C10.2,7.2,10.4,7.2,12,7.2 M12,6c-1.6,0-1.8,0-2.5,0C8.8,6,8.4,6.1,8,6.3C7.6,6.5,7.3,6.7,7,7C6.7,7.3,6.5,7.6,6.3,8 C6.1,8.4,6,8.8,6,9.5C6,10.2,6,10.4,6,12s0,1.8,0,2.5c0,0.7,0.1,1.1,0.3,1.5c0.2,0.4,0.4,0.7,0.7,1c0.3,0.3,0.6,0.5,1,0.7 c0.4,0.2,0.8,0.3,1.5,0.3c0.7,0,0.9,0,2.5,0s1.8,0,2.5,0c0.7,0,1.1-0.1,1.5-0.3c0.4-0.2,0.7-0.4,1-0.7c0.3-0.3,0.5-0.6,0.7-1 c0.2-0.4,0.3-0.8,0.3-1.5c0-0.7,0-0.9,0-2.5s0-1.8,0-2.5c0-0.7-0.1-1.1-0.3-1.5c-0.2-0.4-0.4-0.7-0.7-1c-0.3-0.3-0.6-0.5-1-0.7 C15.6,6.1,15.2,6,14.5,6C13.8,6,13.6,6,12,6L12,6z" />
      <path class="icon-path" d="M12,9c-1.7,0-3,1.3-3,3s1.3,3,3,3s3-1.3,3-3S13.7,9,12,9z M12,13.8c-1,0-1.8-0.8-1.8-1.8S11,10.2,12,10.2 s1.8,0.8,1.8,1.8S13,13.8,12,13.8z" />
      <circle class="icon-path" cx="15.2" cy="8.8" r="0.7" />
    </svg>`,
    linkedin: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="social-icon-svg">
      <circle cx="12" cy="12" r="11" class="icon-circle" />
      <path class="icon-path" d="M8.2,17H6V9h2.2V17z M7.1,8c-0.7,0-1.3-0.6-1.3-1.3c0-0.7,0.6-1.3,1.3-1.3c0.7,0,1.3,0.6,1.3,1.3C8.4,7.4,7.8,8,7.1,8z" />
      <path class="icon-path" d="M18,17h-2.2v-3.9c0-0.8,0-1.9-1.2-1.9c-1.2,0-1.3,0.9-1.3,1.8V17h-2.2V9h2.1v1h0c0.3-0.6,1-1.2,2.1-1.2c2.2,0,2.7,1.5,2.7,3.4V17z" />
    </svg>`,
  };
  return iconMap[platform as keyof typeof iconMap] || "";
};

// Generate social icons from social.json
const socialIcons = socialData.socialIcons.map((social) => ({
  href: social.href,
  icon: getSocialIcon(social.icon),
}));
---

<div class="flex gap-4 items-center">
  {
    socialIcons.map((social) => (
      <a
        href={social.href}
        class="social-icon-link"
        target="_blank"
        rel="noopener noreferrer"
        set:html={social.icon}
      />
    ))
  }
</div>