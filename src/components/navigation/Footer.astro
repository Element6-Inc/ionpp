---
// Footer.astro - Main footer component
// Links are defined in /data/navData.ts

import { Image } from "astro:assets";
import Logo from "../../assets/logos/logo-landscape-white.png";
import CanadaIcon from "../../assets/svg/canada.svg";
import SocialIcons from "../socials/SocialIcons.astro";
import footerData from "../../data/footer.json";
import FooterLinks from "./links/FooterLinks.astro";

const currentYear = new Date().getFullYear();
---

<footer class="bg-stone-950 py-16 mt-auto">
  <div class="container xl:max-w-[1280px] mx-auto px-4">
    <div class="mb-12">
      <a href="/" class="inline-block">
        <Image
          src={Logo}
          alt={footerData.logo.alt}
          class="w-auto h-auto max-w-[250px]"
        />
      </a>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-12 gap-y-8 pb-12"
    >
      <!-- Barrie (col 1) -->
      {(() => {
        const barrie = footerData.contact.locations[0];
        return (
          <div>
            <p class="footer-heading">{barrie.name}</p>
            <p class="footer-text">{barrie.address}</p>
            <ol class="space-y-1 mt-2">
              <li><a href={barrie.phone.href} class="footer-link">{barrie.phone.number}</a></li>
              {barrie.email && (
                <li><a href={barrie.email.href} class="footer-link">{barrie.email.address}</a></li>
              )}
            </ol>
          </div>
        );
      })()}

      <!-- Midland + Vaughan stacked (col 2) -->
      <div class="flex flex-col gap-6">
        {footerData.contact.locations.slice(1).map((location) => (
          <div>
            <p class="footer-heading">{location.name}</p>
            <p class="footer-text">{location.address}</p>
            <ol class="space-y-1 mt-2">
              <li><a href={location.phone.href} class="footer-link">{location.phone.number}</a></li>
              {location.email && (
                <li><a href={location.email.href} class="footer-link">{location.email.address}</a></li>
              )}
            </ol>
          </div>
        ))}
      </div>

      <!-- Hours -->
      <div>
        <p class="footer-heading">Hours</p>
        <div class="space-y-1 mt-2">
          {
            footerData.hours.map((schedule) => (
              <p class="footer-text">
                <span class="font-semibold">{schedule.days}</span>{" "}
                {schedule.time}
              </p>
            ))
          }
        </div>
      </div>

      <!-- Links -->
      <div>
        <p class="footer-heading">Links</p>
        <FooterLinks />
      </div>
    </div>

    <!-- Copyright -->
    <div class="pt-8 border-t border-white/30">
      <div
        class="flex flex-col sm:flex-row justify-between items-center gap-4 text-center sm:text-left"
      >
        <p
          class="footer-copyright sm:order-1 flex flex-col sm:flex-row items-center gap-2"
        >
          <Image src={CanadaIcon} alt="Canada" class="w-5 h-5" />
          <span>© {currentYear} {footerData.copyright.text}</span>
        </p>
        <div class="sm:order-2">
          <SocialIcons />
        </div>
      </div>
    </div>
  </div>
</footer>