---
import Logo from "../../assets/logos/logo-stacked-white.png";
import LogoColour from "../../assets/logos/logo-stacked-colour.png";
import SocialIcons from "../socials/SocialIcons.astro";
import {
  getNavItems,
  type NavLink,
  type NavDropdown,
} from "../../data/navData";

const navItems = getNavItems();

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  const normalized = href.startsWith("/") ? href : "/" + href;
  return pathname === normalized || pathname.startsWith(normalized + "/");
}

function dropdownIsActive(children: NavLink[]): boolean {
  return children.some((child) => isActive(child.href));
}
---

<header class="nav-header absolute inset-x-0 top-0 z-50">
  <div class="mx-auto max-w-7xl">
    <div class="px-6 py-2">
      <nav
        class="flex items-center justify-between lg:justify-start"
        aria-label="Global"
      >
        <!-- Logo -->
        <a href="/" class="-m-1.5 p-1.5">
          <span class="sr-only">Your Company</span>
          <img src={Logo.src} alt="Your Company" class="h-24 w-auto" />
        </a>

        <!-- Mobile Hamburger -->
        <button
          type="button"
          class="-m-2.5 rounded-md p-2.5 text-white transition-colors duration-200 lg:hidden hover:bg-white/10"
          aria-label="Open main menu"
          data-mobile-open
        >
          <span class="sr-only">Open main menu</span>
          <svg
            class="size-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
          </svg>
        </button>

        <!-- Desktop Links -->
        <div
          class="hidden lg:ml-12 lg:flex lg:gap-x-14 items-center"
          data-desktop-nav
        >
          {
            navItems.map((item, index) => {
              const dropdownId = `desktop-${index}`;

              if (item.type === "dropdown") {
                const dd = item.data as NavDropdown;
                return (
                  <div class="dropdown-wrapper">
                    <button
                      type="button"
                      class="dropdown-trigger nav-link"
                      aria-expanded="false"
                      aria-haspopup="true"
                      aria-controls={`dropdown-menu-${dropdownId}`}
                      data-dropdown-trigger={dropdownId}
                      aria-current={dropdownIsActive(dd.children) ? "true" : undefined}
                    >
                      {dd.label}
                      <svg
                        class="dropdown-arrow"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          clip-rule="evenodd"
                          d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                        />
                      </svg>
                    </button>
                    <div
                      id={`dropdown-menu-${dropdownId}`}
                      class="dropdown-menu"
                      data-dropdown-menu={dropdownId}
                      role="menu"
                    >
                      <div class="dropdown-content">
                        {dd.children.map((child) => (
                          <a
                            href={child.href}
                            class="dropdown-item"
                            role="menuitem"
                          >
                            <span class="dropdown-item-title">
                              {child.label}
                            </span>
                          </a>
                        ))}
                      </div>
                    </div>
                  </div>
                );
              }

              const link = item.data as NavLink;
              return (
                <a
                  href={link.href}
                  class="nav-link"
                  aria-current={isActive(link.href) ? "page" : undefined}
                >
                  {link.label}
                </a>
              );
            })
          }
        </div>
      </nav>
    </div>
  </div>
</header>

<!--
  Mobile Overlay — sibling of <header>, NOT a child of it.
  This is the fix for the "menu hidden behind the hero" bug.
-->
<div class="lg:hidden" role="dialog" aria-modal="true" data-mobile-menu hidden>
  <div
    class="fixed inset-0 z-[60] bg-gray-500/50 mobile-backdrop"
    data-mobile-close
  >
  </div>

  <div
    class="fixed inset-y-0 right-0 z-[60] w-full overflow-y-auto bg-gray-100 px-6 py-6 sm:max-w-sm sm:ring-1 sm:ring-gray-200 mobile-panel"
  >
    <!-- Mobile Header -->
    <div class="flex items-center justify-between">
      <a href="/" class="-m-1.5 p-1.5" data-mobile-link>
        <span class="sr-only">Your Company</span>
        <img src={LogoColour.src} alt="Your Company" class="h-20 w-auto" />
      </a>

      <button
        type="button"
        class="-m-2.5 rounded-md p-2.5 text-[#0c0a09] transition-colors duration-200 hover:text-[#3498DB] hover:bg-gray-100 mobile-close-btn"
        aria-label="Close menu"
        data-mobile-close
      >
        <span class="sr-only">Close menu</span>
        <svg
          class="size-6 mobile-close-icon"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18 18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Links -->
    <div class="mt-6 flow-root">
      <div class="-my-6 divide-y divide-gray-200">
        <div class="space-y-2 py-6">
          {
            navItems.map((item, index) => {
              const dropdownId = `mobile-${index}`;

              if (item.type === "dropdown") {
                const dd = item.data as NavDropdown;
                return (
                  <div class="mobile-dropdown">
                    <button
                      type="button"
                      class="mobile-dropdown-trigger"
                      aria-expanded="false"
                      aria-controls={`dropdown-menu-${dropdownId}`}
                      data-dropdown-trigger={dropdownId}
                      aria-current={dropdownIsActive(dd.children) ? "true" : undefined}
                    >
                      <span>{dd.label}</span>
                      <svg
                        class="mobile-dropdown-arrow"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                        width="20"
                        height="20"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          clip-rule="evenodd"
                          d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                        />
                      </svg>
                    </button>
                    <div
                      id={`dropdown-menu-${dropdownId}`}
                      class="mobile-dropdown-menu"
                      data-dropdown-menu={dropdownId}
                    >
                      {dd.children.map((child) => (
                        <a
                          href={child.href}
                          class="mobile-dropdown-item"
                          data-mobile-link
                        >
                          {child.label}
                        </a>
                      ))}
                    </div>
                  </div>
                );
              }

              const link = item.data as NavLink;
              return (
                <a
                  href={link.href}
                  class="mobile-nav-link"
                  data-mobile-link
                  aria-current={isActive(link.href) ? "page" : undefined}
                >
                  {link.label}
                </a>
              );
            })
          }
        </div>

        <hr class="border-gray-300" />

        <div class="py-6 flex justify-left">
          <SocialIcons />
        </div>
      </div>
    </div>
  </div>
</div>
