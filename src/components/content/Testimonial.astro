---
import { Image } from "astro:assets";
import Rating from "../../assets/svg/rating.svg";
import content from "../../data/testimonials.json";

const { sectionTitle, maxChars, items } = content.testimonials;

function truncate(text: string, limit: number): string {
  if (text.length <= limit) return text;
  // Find the last sentence-ending punctuation at or before the limit
  const segment = text.slice(0, limit);
  const sentenceEnd = Math.max(
    segment.lastIndexOf(". "),
    segment.lastIndexOf("! "),
    segment.lastIndexOf("? "),
  );
  if (sentenceEnd > 0) return text.slice(0, sentenceEnd + 1);
  // Fall back to word boundary if no sentence end found
  const wordEnd = segment.lastIndexOf(" ");
  return text.slice(0, wordEnd > 0 ? wordEnd : limit) + "…";
}
---

<!--
  NOTE: testimonial.js is imported once in Layout.astro and initialises via
  astro:page-load. Do not re-add the <script> tag here — it would register
  a duplicate listener and double-advance the slider on every navigation.
-->

<section class="px-6 py-10 sm:py-24 lg:px-8 flex items-center bg-slate-50">
  <div class="mx-auto max-w-3xl text-center w-full">

    <!-- Screen reader accessibility text -->
    <p class="sr-only">5 out of 5 stars</p>

    <!-- Star rating display -->
    <div class="flex gap-x-1 justify-center mb-5">
      <Image
        src={Rating}
        alt="5 star rating"
        class="h-5 w-auto"
        width={200}
        height={48}
      />
    </div>

    <!-- Section title and decorative line -->
    <h3 class="text-center mb-4">{sectionTitle}</h3>
    <div class="testimonial-rule"></div>

    <!-- Testimonial content area -->
    <div class="testimonial-container">

      <!-- Quote + author — each item rendered server-side, toggled by JS -->
      <div class="testimonial-track" aria-live="polite" aria-atomic="true">
        {items.map((item, index) => (
          <figure
            class="testimonial-slide"
            data-index={index}
            aria-hidden={index !== 0}
          >
            <p class="testimonial-text">{truncate(item.content, maxChars)}</p>
            <figcaption class="testimonial-author">
              <span>{item.author}</span>
            </figcaption>
          </figure>
        ))}
      </div>

      <!-- Pagination dots -->
      <nav class="testimonial-pagination" aria-label="Testimonial navigation">
        {items.map((item, index) => (
          <button
            class={`testimonial-dot${index === 0 ? " active" : ""}`}
            data-index={index}
            aria-label={`Show testimonial from ${item.author}`}
            aria-current={index === 0}
          />
        ))}
      </nav>

    </div>
  </div>
</section>