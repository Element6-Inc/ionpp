---
import { readFileSync } from 'fs';
import { fileURLToPath } from 'url';
import { resolve, dirname } from 'path';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

// Read SVGs and convert to base64 data URIs for use in CSS background-image
const shapesRaw = readFileSync(resolve(__dirname, '../../assets/svg/shapes.svg'));
const circleRaw = readFileSync(resolve(__dirname, '../../assets/svg/circle.svg'));

const shapesSrc = `data:image/svg+xml;base64,${shapesRaw.toString('base64')}`;
const circleSrc = `data:image/svg+xml;base64,${circleRaw.toString('base64')}`;

interface Props {
  heading: string;
  button: string;
  link: string;
  bgColor?: string;
}

const {
  heading,
  button,
  link,
} = Astro.props;
---

<section class="cta">
  <div
    class="cta-inner"
    style={`background-image: url('${shapesSrc}'), url('${circleSrc}');`}
  >
    <div class="cta-container">

      <div class="cta-content">
        <h3 class="cta-heading">{heading}</h3>
      </div>

      <div class="cta-action">
        <a
          class="btn btn-cta-white"
          href={link}
        >
          {button}
        </a>
      </div>

    </div>
  </div>
</section>