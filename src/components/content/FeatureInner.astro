---
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  buttonText?: string;
  buttonLink?: string;
  buttonTarget?: string;
  imageSrc: ImageMetadata;
  imageAlt: string;
}

const {
  title,
  description,
  buttonText,
  buttonLink,
  buttonTarget,
  imageSrc,
  imageAlt,
} = Astro.props;

const showButton = buttonText && buttonLink;
---

<div class="overflow-hidden py-10 sm:py-14">
  <div class="mx-auto max-w-7xl px-6 md:px-10 lg:px-16">
    <div
      class="grid grid-cols-1 gap-x-16 gap-y-10 sm:gap-y-16 lg:grid-cols-[3fr_2fr] lg:items-center lg:px-22"
    >
      <!-- Content: second on mobile, first on desktop -->
      <div class="order-2 lg:order-1">
        <h3 class="feat-inner-title">{title}</h3>
        <div class="mt-4 inner-feature-description" set:html={description} />

        {
          showButton && (
            <div class="mt-8">
              <a
                href={buttonLink}
                target={buttonTarget || "_self"}
                rel={
                  buttonTarget === "_blank" ? "noopener noreferrer" : undefined
                }
                class="inline-block btn btn-secondary"
              >
                {buttonText}
              </a>
            </div>
          )
        }
      </div>

      <!-- Image: first on mobile (square), tall portrait on desktop -->
      <div class="order-1 lg:order-2">
        <div class="overflow-hidden md:rounded-tr-4xl md:rounded-bl-4xl">
          <Image
            src={imageSrc}
            alt={imageAlt}
            width={600}
            height={900}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 600px"
            loading="lazy"
            decoding="async"
            class="feat-inner-img w-full object-cover object-center"
          />
        </div>
      </div>
    </div>
  </div>
</div>
