---
interface Props {
  flip?: boolean;
  className?: string;
}

const { flip = false, className = '' } = Astro.props;
---

<div 
  class={`shape-divider ${flip ? 'flip' : ''} ${className}`}
  aria-hidden="true"
>
  <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
    <path d="M985.66,92.83C906.67,72,823.78,31,743.84,14.19c-82.26-17.34-168.06-16.33-250.45.39-57.84,11.73-114,31.07-172,41.86A600.21,600.21,0,0,1,0,27.35V120H1200V95.8C1132.19,118.92,1055.71,111.31,985.66,92.83Z" class="shape-fill"></path>
  </svg>
</div>

<style>
  .shape-divider {
    position: relative;
    width: 100%;
    line-height: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
  }

  .shape-divider svg {
    display: block;
    width: 100%;
    height: 60px;
  }

  .shape-divider .shape-fill {
    fill: #ffffff;
  }

  .shape-divider.flip {
    transform: scaleY(-1);
  }

  /* Hide on mobile */
  @media (max-width: 768px) {
    .shape-divider {
      display: none;
    }
  }
</style>